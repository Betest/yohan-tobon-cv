---
import Section from "../Section.astro"
import type { CV } from "@/cv"

interface Props {
  education: CV["education"]
  title: string
  certificateLabel: string
}

const { education, title, certificateLabel } = Astro.props
const COURSE_TYPES = ["Curso", "Course"]
---

<Section title={title}>
  <ul>
    {
      education.map(({ institution, startDate, endDate, area, url, studyType }) => {
        const startYear = startDate.slice(0, 4)
        const endYear = endDate != null ? endDate.slice(0, 4) : "Actual"
        const years = `${startYear} - ${endYear}`

        return (
          <li>
            <article>
              <header>
                <div>
                  <h3>{institution}</h3>
                </div>

                <time>{years}</time>
              </header>

              <footer>
                <p>{area}</p>
                {
                  COURSE_TYPES.includes(studyType) ? (
                    <a href={url}>{certificateLabel}</a>
                  ) : null
                }
              </footer>
            </article>
          </li>
        )
      })
    }
  </ul>
</Section>

<style>
  ul {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  article h3 {
    font-weight: 500;
    color: #111;
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 4px;
  }

  time {
    color: #555;
    font-size: 0.85rem;
    min-width: 102px;
  }

  @media (width <= 700px) {
    time {
      text-align: right;
    }
  }

  @media (prefers-color-scheme: dark) {

    li h3 {
      color: rgba(255, 255, 255, 0.9);
    }

    time {
      color: rgba(255, 255, 255, 0.9);
    }
  }
</style>
